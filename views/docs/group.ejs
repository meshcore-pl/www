<%- include('../includes/header.ejs', {
	title,
	description,
	pageStyle: 'docs',
}) %>

<main>
	<section class="docs-hero">
		<div class="section__inner">
			<nav class="docs-breadcrumb" aria-label="Okruszki">
				<a href="/dokumentacja">Dokumentacja</a>
				<span aria-hidden="true">/</span>
				<span aria-current="page"><%= group.title %></span>
			</nav>
			<div class="docs-hero__head">
				<div class="docs-hero__icon">
					<% if (group.icon.startsWith('/')) { %><img src="<%= group.icon %>" alt="" width="64" height="64"><% } else { %><%= group.icon %><% } %>
				</div>
				<div>
					<p class="eyebrow">Kategoria</p>
					<h1><%= group.title %></h1>
				</div>
			</div>
			<p class="docs-hero__lead"><%= group.description %></p>
			<div class="docs-hero__actions">
				<a href="/dokumentacja/<%= group.slug %>/<%= group.pages[0].slug %>" class="btn btn--primary">Zacznij od: <%= group.pages[0].title %></a>
				<span class="docs-hero__count"><%= group.pages.length %> <%= group.pages.length === 1 ? 'strona' : 'strony' %></span>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="section__inner">
			<div class="docs-page-grid">
				<% group.pages.forEach((p, i) => { %>
				<a href="/dokumentacja/<%= group.slug %>/<%= p.slug %>" class="docs-page-card">
					<span class="docs-page-card__num"><%= String(i + 1).padStart(2, '0') %></span>
					<span class="docs-page-card__title"><%= p.title %></span>
					<span class="docs-page-card__arrow" aria-hidden="true">&rarr;</span>
				</a>
				<% }) %>
			</div>
		</div>
	</section>
</main>

<%- include('../includes/footer.ejs') %>
