<%- include('../includes/header.ejs', {
	title: 'Dokumentacja - MeshCore Polska',
	description: 'Dokumentacja MeshCore Polska: regulamin i informacje o serwerze Discord oraz poradniki związane z siecią MeshCore.',
	keywords: 'dokumentacja MeshCore Polska, poradniki MeshCore, LoRa, konfiguracja MeshCore',
	canonical: '/dokumentacja',
	css: 'docs',
	page: 'docs'
}) %>

<main>
	<section class="docs-hero">
		<div class="section__inner">
			<p class="eyebrow">Dokumentacja</p>
			<h1>Dokumentacja MeshCore Polska</h1>
			<p class="docs-hero__lead">Znajdziesz tu informacje o naszym serwerze Discord, natomiast materiały o MeshCore pojawią się wkrótce. Strona jest jeszcze w budowie. Jeśli masz jakieś propozycje, podziel się nimi na naszym Discordzie.</p>
		</div>
	</section>

	<section class="section">
		<div class="section__inner">
			<div class="docs-groups">
				<% groups.forEach(group => { %>
				<a href="/dokumentacja/<%= group.slug %>" class="docs-group-card">
					<div class="docs-group-card__icon">
						<% if (group.icon.startsWith('/')) { %><img src="<%= group.icon %>" alt="<%= group.title %>" width="40" height="40" loading="lazy"><% } else { %><%= group.icon %><% } %>
					</div>
					<div class="docs-group-card__body">
						<div class="docs-group-card__head">
							<h2><%= group.title %></h2>
							<span class="docs-group-card__badge"><%= group.pages.length %> <%= group.pages.length === 1 ? 'strona' : 'strony' %></span>
						</div>
						<p><%= group.description %></p>
					</div>
				</a>
				<% }) %>
			</div>
		</div>
	</section>
</main>

<%- include('../includes/footer.ejs', { footer: false }) %>
