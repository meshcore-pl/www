<%- include('./includes/header.ejs', {
	title: 'MeshCore Polska - ogólnopolska społeczność sieci mesh',
	description: 'MeshCore Polska to ogólnopolska społeczność użytkowników sieci MeshCore. Budujemy niezależną sieć komunikacji LoRa działającą bez internetu i GSM. Dołącz na nasz serwer Discord.',
	keywords: 'MeshCore Polska, sieć mesh, LoRa, komunikacja bez internetu, radio, repeater, companion',
	canonical: '/',
